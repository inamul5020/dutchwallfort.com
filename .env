# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dutchwallfort

# API Configuration
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dutchwallfort
JWT_SECRET=dev-jwt-secret-key-change-in-production-2024
SESSION_SECRET=dev-session-secret-key-change-in-production-2024

# Frontend Configuration
VITE_API_URL=http://localhost:3000

# Email Configuration (required for booking confirmations and contact forms)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
